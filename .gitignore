# ══════════════════════════════════════════════════════════════
# TAKUMI Trader — .gitignore
# Repo went private 2026-05-06. Proprietary exclusions removed;
# hygiene exclusions retained.
# ══════════════════════════════════════════════════════════════

# ── Data & results (runtime journals, calibration, backups) ───
data/
*.json
BACKUP/

# ── Build artifacts ───────────────────────────────────────────
dist/
build/
*.spec
*.exe

# ── Python ────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*.pyo
*.egg-info/
*.egg
.eggs/

# ── IDE / OS ──────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
Thumbs.db
Desktop.ini
.DS_Store

# ── Claude Code session state ─────────────────────────────────
.claude/

# ── Resources cleanup ─────────────────────────────────────────
takumi_trader/resources/OLD/

# ── Analysis scratch (private to working tree, not source) ────
# Underscore-prefixed top-level scripts are ad-hoc forensic work,
# not maintained code. Same for the prompt drafts and cache dirs.
_phase*.py
_analysis_cache/
analysis/
WEEKLY_PROMPT.md
PAIR_ANALYSIS_PROMPT.md

# ── Misc ──────────────────────────────────────────────────────
*.log
crash_log.txt
_create_shortcut.vbs
create_settings_doc.py
Forex_Scalper_PRO_System_Documentation.docx
RunTAKUMI.bat
